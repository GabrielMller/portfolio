#RAML 1.0 DataType
type: object
properties:
  title:
    type: string
    description: Título da sugestão
    example: "Melhoria na interface do usuário"
    minLength: 5
  description:
    minLength: 10
    type: string
    description: Descrição detalhada da sugestão
    example: "Seria ótimo ter um modo escuro para facilitar a leitura à noite."