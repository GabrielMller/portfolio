#RAML 1.0 DataType
type: object
properties:
  id:
    type: string
    example: "123e4567-e89b-12d3-a456-426614174000"
  name:
    type: string
    example: "Item 1"
  image:
    type: string
    example: "https://example.com/images/item1.jpg"
  description:
    type: string
    example: "Descrição do item 1"
  quantity:
    type: integer
    example: 2
  price:
    type: number
    example: 19.99