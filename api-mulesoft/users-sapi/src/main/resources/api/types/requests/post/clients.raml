#RAML 1.0 DataType
type: object
properties:
  userId:
    type: integer
    example: 123
  name:
    type: string
    example: "John Doe"
  status?:
    type: string
    example: "LEAD"
    default: "LEAD"
  document?:
    type: string
    example: "12345678900"
  documentType?:
    type: string
    example: "CPF"