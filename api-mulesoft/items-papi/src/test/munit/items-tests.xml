	<munit:test name="get-temes-test" doc:id="2bdad844-9dd2-46d2-b410-4e55a0e49f1b" >
		<munit:behavior >
			<munit-tools:spy doc:name="Spy" doc:id="f5b80b22-9ab6-4a59-a66d-94328a8f6565" processor="http:request">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="4c6aa6ed-b5fd-4a15-899e-1f5014bbadf2" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:before-call >
					<munit-tools:assert-that doc:name="Assert that" doc:id="a8a05c24-455d-488d-8324-2e60e914e289" is="#[MunitTools::equalTo(10)]" expression="#[vars.itemsQuery.limit]"/>
					<munit-tools:assert-that doc:name="Assert that" doc:id="1570e605-6991-4e06-9224-222373e14996" expression="#[vars.itemsQuery.offset]" is="#[MunitTools::equalTo(0)]" />
				</munit-tools:before-call>
			</munit-tools:spy>
			<munit-tools:mock-when doc:name="Mock when" doc:id="7b30d9c8-b639-4b10-a593-c11afc38e1f4" processor="http:request">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="4c6aa6ed-b5fd-4a15-899e-1f5014bbadf2" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:payload value="#[output json&#10;---&#10;readUrl('classpath://mocks/getItems.json','json')]" mediaType="application/json" encoding="UTF-8" />
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution >
			<set-variable value="#[output json&#10;---&#10;{&#10;	pageSize: 10,&#10;	page: 1&#10;}]" doc:name="Set Variable" doc:id="3a645fad-dff7-49f6-9401-9aad4344217c" variableName="query"/>
			<flow-ref doc:name="Flow Reference" doc:id="26581573-c561-4409-8d13-52f8883aec59" name="getItems"/>
		</munit:execution>
		<munit:validation>
			<munit-tools:assert-equals doc:name="Assert equals" doc:id="37c05c3b-d44f-4fc0-b082-3782f643af05" actual="#[output json&#10;---&#10;payload.metadata]" expected='#[output json&#10;---&#10;{&#10;	"totalItems": 0,&#10;	"page": 1,&#10;	"pageSize": 10&#10;}]'/>
		</munit:validation>
	</munit:test>


