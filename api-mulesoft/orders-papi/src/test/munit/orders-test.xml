<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:munit="http://www.mulesoft.org/schema/mule/munit" xmlns:munit-tools="http://www.mulesoft.org/schema/mule/munit-tools"
	xmlns="http://www.mulesoft.org/schema/mule/core" xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xsi:schemaLocation="
		http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
		http://www.mulesoft.org/schema/mule/munit http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd
		http://www.mulesoft.org/schema/mule/munit-tools  http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd">
	<munit:config name="orders-test.xml" />
	<munit:test name="create-order-test" doc:id="49f5365c-4cf7-49b5-8ece-ebc4702a583e" >
		<munit:behavior >
			<munit-tools:mock-when doc:name="Mock when" doc:id="6dfa32eb-74ae-4d73-88a7-a1386a2f6ed6" processor="http:request">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="43038c3f-0c65-44b0-9e7e-be47f661923e" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:variables >
						<munit-tools:variable key="dbError" value="#[output json --- false]" mediaType="application/json" encoding="UTF-8" />
					</munit-tools:variables>
				</munit-tools:then-return>
			</munit-tools:mock-when>
			<munit-tools:mock-when doc:name="Mock when" doc:id="6de5d24b-6dd3-40b8-8455-6c080a53b783" processor="kafka:publish-message">
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution >
			<munit:set-event doc:name="Set Event" doc:id="bf75bef2-65eb-4598-bd28-34d767c3f67e" >
				<munit:payload value="#[output json&#10;---&#10;readUrl('classpath://mocks/order.json','json')]" encoding="UTF-8" mediaType="application/json" />
			</munit:set-event>
			<flow-ref doc:name="Flow Reference" doc:id="d3350410-ac07-4cf6-b4a9-5f9723f4b30e" name="createOrder"/>
		</munit:execution>
		<munit:validation >
			<munit-tools:assert-equals doc:name="Assert equals" doc:id="a8d4df23-51c1-4134-ba7f-b578b5034473" actual="#[payload.description]" expected='#["Success processing order"]'/>
		</munit:validation>
	</munit:test>
	<munit:test name="create-order-error-test" doc:id="9823294b-0ff3-4850-b30e-d141a32edfb1" >
		<munit:execution >
			<munit:set-event doc:name="Set Event" doc:id="e2fdf10e-c097-433f-9bf4-eac75efffbb1" >
				<munit:payload value="#[output json&#10;---&#10;readUrl('classpath://mocks/order.json','json')]" encoding="UTF-8" mediaType="application/json" />
				<munit:variables >
					<munit:variable key="query" value='#[output json --- readUrl("classpath://mocks/query.json")]' encoding="UTF-8" mediaType="application/json" />
				</munit:variables>
			</munit:set-event>
			<flow-ref doc:name="Flow Reference" doc:id="d4b5b622-b11f-4f4b-8b81-8332582dc1e4" name="createOrder" />
		</munit:execution>
		<munit:validation >
			<munit-tools:assert-equals doc:name="Assert equals" doc:id="98b2d7ea-dc91-440c-aa0c-586486ecb63d" actual="#[payload.description]" expected='#["Order will be processed as soon as possible"]' />
		</munit:validation>
	</munit:test>
	<munit:test name="order-created-items-errors" doc:id="e4219d96-982d-4d99-b0d8-53e00909d2cd">
		<munit:behavior >
			<munit-tools:mock-when doc:name="Mock when" doc:id="ce16f38a-44ef-405e-8167-6c636f3d6773" processor="http:request">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="a8fe5412-c43e-42f1-860a-daa0a79c93fe" attributeName="doc:id" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:variables >
						<munit-tools:variable key="item" value="#[output json --- {}]" mediaType="application/json" encoding="UTF-8" />
					</munit-tools:variables>
				</munit-tools:then-return>
			</munit-tools:mock-when>
		</munit:behavior>
		<munit:execution >
			<set-payload value='#[output json&#10;---&#10;{&#10;  "paymentMethod": "PIX",&#10;  "items": [&#10;    {&#10;      "price": 2399.99,&#10;      "id": "0065b4b1-5e4e-4dac-8352-0ab4d6a990ce",&#10;      "quantity": 2&#10;    }&#10;  ],&#10;  "userId": 1,&#10;  "id": "8a1f2977-8cb7-403d-b4f1-aea3cf8750e3",&#10;  "status": "pending",&#10;  "action": "update",&#10;  "eventId": "61c44ace-c494-4ea3-ae42-cf3522ce84ca"&#10;}]' doc:name="Set Payload" doc:id="5a9b947e-ead2-40cd-9457-a440410cba3a" />
			<flow-ref doc:name="Flow Reference" doc:id="2320092a-c7b2-48c5-a8f8-ee4fb8bde53b" name="orderCreated"/>
		</munit:execution>
		<munit:validation >
			<munit-tools:assert-that doc:name="Assert that" doc:id="1fd5da12-c560-49d6-8feb-ea84e90b1349" is="#[MunitTools::notNullValue()]" expression="#[output json&#10;---&#10;vars.errorItems[0]]"/>
		</munit:validation>
	</munit:test>


</mule>
